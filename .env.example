# ============================================================
# Salin file ini ke .env lalu isi nilainya:
#   cp .env.example .env
# JANGAN commit file .env ke git.
# ============================================================

# --- Database MySQL ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=plnjabar_user
DB_PASSWORD=ganti_ini_dengan_password_kuat
DB_NAME=plnjabar_portal
# Set ke "true" kalau provider MySQL kamu butuh SSL (biasanya hosting cloud)
DB_SSL=false

# --- Session & enkripsi ---
# Generate keduanya dengan:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Jalankan DUA KALI — hasil berbeda untuk masing-masing variabel.
SESSION_SECRET=ganti_ini_64_karakter_hex_random
FIELD_ENCRYPTION_KEY=ganti_ini_64_karakter_hex_random

# --- Cookie ---
# Set ke "true" HANYA kalau situs sudah diakses lewat HTTPS.
# Kalau masih HTTP (mis. development local), biarkan false —
# kalau di-set true di HTTP, cookie tidak pernah terkirim dan login selalu gagal.
COOKIE_SECURE=false
# Opsional — isi kalau butuh cookie lintas subdomain (mis. app.example.com)
# COOKIE_DOMAIN=

# --- Server ---
PORT=3000

# --- Session duration ---
# Berapa jam sesi login aktif sebelum kedaluwarsa (default: 12)
SESSION_DURATION_HOURS=12

# --- AI Chatbot ---
# Dapatkan API key gratis di https://aistudio.google.com/app/apikey
GROQ_API_KEY=ganti_ini_dengan_api_key_groq

# --- Account lockout ---
# Berapa kali gagal login sebelum akun terkunci sementara (default: 5)
MAX_LOGIN_ATTEMPTS=5
# Berapa menit akun terkunci setelah melebihi batas (default: 15)
LOCKOUT_DURATION_MINUTES=15
