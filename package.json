{
  "name": "cockpit",
  "version": "0.3.0",
  "description": "COCKPIT — Pusat Data Riset Pribadi untuk mendukung studi PhD",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && echo '=== BUILD OK ===' && node --version && ls dist/index.js",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "create-admin": "tsx src/scripts/createAdmin.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@hono/node-server": "^1.13.7",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.2",
    "groq-sdk": "^1.3.0",
    "hono": "^4.6.13",
    "mysql2": "^3.11.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
